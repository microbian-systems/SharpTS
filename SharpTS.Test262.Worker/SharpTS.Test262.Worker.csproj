<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Subprocess worker for Test262 batch execution. Issued by the in-process
    Test262Tests harness once per batch; receives test paths on stdin, emits
    JSON-lines results on stdout, exits when the input stream closes.

    Designed so a pathological test that allocates gigabytes (or otherwise
    crashes the worker) only loses its enclosing batch — the parent restarts
    a fresh worker for the next one, releasing all memory. See issue #109.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- TargetFramework / ImplicitUsings / Nullable inherited from Directory.Build.props. -->
    <RootNamespace>SharpTS.Test262.Worker</RootNamespace>
    <AssemblyName>SharpTS.Test262.Worker</AssemblyName>
    <!-- Server GC: workers do back-to-back compile + ALC unload — workstation GC's
         per-thread stop-the-world hurts on the 50-test forced-GC cycle. -->
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
  </PropertyGroup>

  <!-- Share the runner code with the in-process test project rather than
       refactor into a third library. The two projects compile identical
       Test262Runner / Test262HarnessAssembler / etc. into separate
       assemblies, which is fine: the test project never references the
       worker assembly directly — it spawns it as a subprocess. -->
  <ItemGroup>
    <Compile Include="..\SharpTS.Test262\Test262Runner.cs" />
    <Compile Include="..\SharpTS.Test262\Test262HarnessAssembler.cs" />
    <Compile Include="..\SharpTS.Test262\Test262Metadata.cs" />
    <Compile Include="..\SharpTS.Test262\Test262Outcome.cs" />
    <Compile Include="..\SharpTS.Test262\Test262Paths.cs" />
    <Compile Include="..\SharpTS.Test262\Test262Config.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SharpTS.csproj" />
  </ItemGroup>

</Project>
